# Single-host development / 1-2 concurrent voice sessions.
LOCAL_PROFILE=small
RUNTIME_DISPATCHER=local
GATEWAY_SESSION_MAX_CONCURRENT=1
GATEWAY_GLOBAL_MAX_CONCURRENT=4
VOICE_MAX_SESSIONS=2
VLLM_MAX_MODEL_LEN=4096
VLLM_MAX_NUM_SEQS=4
S2S_MODE=shadow
S2S_AUDIO_RING_MS=10000
S2S_SUBSCRIBER_QUEUE_FRAMES=64
