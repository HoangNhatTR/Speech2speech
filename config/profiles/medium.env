# Single-host workstation / up to roughly 4-8 voice sessions after load testing.
LOCAL_PROFILE=medium
RUNTIME_DISPATCHER=local
GATEWAY_SESSION_MAX_CONCURRENT=2
GATEWAY_GLOBAL_MAX_CONCURRENT=16
VOICE_MAX_SESSIONS=8
VLLM_MAX_MODEL_LEN=8192
VLLM_MAX_NUM_SEQS=16
S2S_MODE=shadow
S2S_AUDIO_RING_MS=30000
S2S_SUBSCRIBER_QUEUE_FRAMES=128
