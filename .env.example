# Sao chép file này thành ".env" rồi điền API key thật vào (không commit .env).

# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Bỏ trống để dùng model mặc định trong bot.py, hoặc ghi đè, vd: claude-sonnet-4-6
ANTHROPIC_MODEL=

# https://console.deepgram.com/  (Nova-3 hỗ trợ tiếng Việt streaming)
DEEPGRAM_API_KEY=
DEEPGRAM_LANGUAGE=vi

# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# ID giọng đọc lấy từ https://elevenlabs.io/app/voice-library (voice của bạn, không phải model)
ELEVENLABS_VOICE_ID=
# eleven_flash_v2_5 là model duy nhất của ElevenLabs hỗ trợ tiếng Việt (độ trễ ~75ms)
ELEVENLABS_MODEL=eleven_flash_v2_5

# Event Bus — chạy qua Docker: docker run -d --name nats -p 4222:4222 nats:latest -js
NATS_URL=nats://localhost:4222

# Gateway — auth tối giản. Để true khi dev local (giao diện thử nghiệm WebRTC không gửi
# header tuỳ chỉnh được). Đặt false + điền GATEWAY_API_KEYS trước khi mở ra ngoài localhost.
GATEWAY_AUTH_DISABLED=true
GATEWAY_API_KEYS=changeme-dev-key

# ===== Giai đoạn 1 — tự host tiếng Việt (xem docs/platform-architecture.md) =====
# Mỗi khối bật riêng bằng *_BACKEND=local (mặc định cloud). Chưa đổi thì bỏ qua phần này.

# STT: Zipformer-30M-RNNT qua sherpa-onnx — ĐÃ verify chạy tốt trên CPU.
# Tải model trước: python scripts/download_asr_model.py
STT_BACKEND=cloud
ASR_MODEL_DIR=models/asr-vi/sherpa-onnx-zipformer-vi-30M-int8-2026-02-09

# LLM: Qwen3 qua vLLM (API tương thích OpenAI) — CHƯA chạy thử được trên máy dev (vLLM
# không có wheel Windows, cần WSL2/Linux + GPU đủ VRAM cho model 8B). Xem
# docs/platform-architecture.md để biết lệnh `vllm serve`.
LLM_BACKEND=cloud
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=Qwen/Qwen3-8B-Instruct
VLLM_API_KEY=not-needed

# TTS: F5-TTS-Vietnamese-ViVoice qua selfhost/tts_server.py (venv riêng .venv-tts) —
# CHƯA chạy thử được (checkpoint ~5GB, cần GPU đủ VRAM để suy luận đủ nhanh). Voice
# cloning zero-shot BẮT BUỘC audio+text tham chiếu của giọng bạn có quyền sử dụng
# (đã xin phép người nói) — xem docstring trong selfhost/tts_server.py.
TTS_BACKEND=cloud
F5_TTS_SERVER_URL=http://localhost:8100
F5_TTS_CKPT_FILE=
F5_TTS_VOCAB_FILE=
F5_TTS_REF_AUDIO=
F5_TTS_REF_TEXT=

# ===== Track B — 7 service phía sau Runtime Scheduler (Vision/Text/Tool/Memory/
# Planning/Reasoning/Generation), tách biệt với LLM_BACKEND của Speech Service ở trên =====
SERVICES_LLM_BACKEND=cloud
SERVICES_VLLM_BASE_URL=http://localhost:8000/v1
SERVICES_VLLM_MODEL=Qwen/Qwen3-8B-Instruct
SERVICES_VLLM_API_KEY=not-needed
