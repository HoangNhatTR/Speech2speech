# Sao chép file này thành ".env" rồi điền API key thật vào (không commit .env).

# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Bỏ trống để dùng model mặc định trong bot.py, hoặc ghi đè, vd: claude-sonnet-4-6
ANTHROPIC_MODEL=

# https://console.deepgram.com/  (Nova-3 hỗ trợ tiếng Việt streaming)
DEEPGRAM_API_KEY=
DEEPGRAM_LANGUAGE=vi

# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# ID giọng đọc lấy từ https://elevenlabs.io/app/voice-library (voice của bạn, không phải model)
ELEVENLABS_VOICE_ID=
# eleven_flash_v2_5 là model duy nhất của ElevenLabs hỗ trợ tiếng Việt (độ trễ ~75ms)
ELEVENLABS_MODEL=eleven_flash_v2_5
