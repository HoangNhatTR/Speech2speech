# Sao chép file này thành ".env" rồi điền API key thật vào (không commit .env).

# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Bỏ trống để dùng model mặc định trong bot.py, hoặc ghi đè, vd: claude-sonnet-4-6
ANTHROPIC_MODEL=

# https://console.deepgram.com/  (Nova-3 hỗ trợ tiếng Việt streaming)
DEEPGRAM_API_KEY=
DEEPGRAM_LANGUAGE=vi

# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# ID giọng đọc lấy từ https://elevenlabs.io/app/voice-library (voice của bạn, không phải model)
ELEVENLABS_VOICE_ID=
# eleven_flash_v2_5 là model duy nhất của ElevenLabs hỗ trợ tiếng Việt (độ trễ ~75ms)
ELEVENLABS_MODEL=eleven_flash_v2_5

# Event Bus — chạy qua Docker: docker run -d --name nats -p 4222:4222 nats:latest -js
NATS_URL=nats://localhost:4222

# ===== Triển khai local small/medium =====
# Dùng `python -m scripts.local_stack start --profile small|medium`. Các giá trị trong
# config/profiles/*.env là mặc định an toàn; giá trị khai báo trong .env này sẽ ưu tiên
# hơn profile. Giữ RUNTIME_DISPATCHER=local trên một máy để không khởi tạo Ray/Plasma.
RUNTIME_DISPATCHER=local
# small mặc định 2 voice session / 1 request mỗi session / 4 request toàn cục;
# medium mặc định 8 / 2 / 16. Chỉ ghi đè khi đã đo đủ CPU/GPU/RAM.
# VOICE_MAX_SESSIONS=2
# GATEWAY_SESSION_MAX_CONCURRENT=1
# GATEWAY_GLOBAL_MAX_CONCURRENT=4
# Giới hạn vLLM khi launcher phải tự khởi động server. Profile small: 4096/4;
# medium: 8192/16. Server vLLM đã chạy sẵn sẽ được tái sử dụng, không restart.
# VLLM_MAX_MODEL_LEN=4096
# VLLM_MAX_NUM_SEQS=4

# Gateway — auth tối giản. Để true khi dev local (giao diện thử nghiệm WebRTC không gửi
# header tuỳ chỉnh được). Đặt false + điền GATEWAY_API_KEYS trước khi mở ra ngoài localhost.
GATEWAY_AUTH_DISABLED=true
GATEWAY_API_KEYS=changeme-dev-key

# ===== Giai đoạn 1 — tự host tiếng Việt (xem docs/platform-architecture.md) =====
# Mỗi khối bật riêng bằng *_BACKEND=local (mặc định cloud). Chưa đổi thì bỏ qua phần này.

# STT: Zipformer train trên ~70.000 giờ (mặc định, xem scripts/download_asr_model.py)
# — ĐÃ ĐO: WER tổng 2.7%, code-switch 14.3%, latency ~65ms/câu — tốt hơn rõ rệt so
# với bản 30M cũ (3.5%/18.1%/~40ms) trên benchmark tổng hợp; chênh lệch thật trên
# giọng nói tự nhiên nhiều khả năng còn lớn hơn (train trên nhiều dữ liệu hơn ~10x).
# Tải model trước: python scripts/download_asr_model.py (--variant small nếu cần nhẹ hơn)
STT_BACKEND=cloud
ASR_MODEL_DIR=models/asr-vi/sherpa-onnx-zipformer-vi-int8-2025-04-20
# whisper: Whisper large-v3-turbo qua sherpa-onnx — ĐÃ đo bằng eval/asr_wer.py:
# WER tổng 12.5% (thua Zipformer 3.5% ở hầu hết domain), latency ~2474ms/câu
# (~62x chậm hơn Zipformer) — KHÔNG khuyến nghị làm mặc định, chỉ để thử/so sánh.
# Tải model: python scripts/download_whisper_asr_model.py
ASR_LOCAL_ENGINE=zipformer
WHISPER_ASR_MODEL_DIR=models/whisper-turbo

# LLM: Qwen3-8B-AWQ qua vLLM (API tương thích OpenAI) — ĐÃ verify chạy thật trên GPU
# (venv riêng .venv-vllm, ~15 phút khởi động lần đầu do biên dịch kernel CUDA cho
# GPU mới). Bản AWQ (~6.1GB) thay vì bf16 gốc (~16GB) vì máy chạy chung nhiều người,
# RAM/VRAM hạn chế theo thời điểm. QUAN TRỌNG: lệnh `vllm serve` BẮT BUỘC có
# `--default-chat-template-kwargs '{"enable_thinking": false}'` — thiếu cờ này Qwen3
# tự sinh rất nhiều token suy luận <think> trước khi trả lời (đã đo thật: 229 token,
# nhiều giây/lượt), quá chậm cho voice chat. Có cờ: ~60-70 token/lượt, nhanh hơn
# nhiều, tool-calling vẫn hoạt động 100%. Lệnh đầy đủ: xem
# docs/platform-architecture.md mục "Giai đoạn 1".
LLM_BACKEND=cloud
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=Qwen/Qwen3-8B-AWQ
VLLM_API_KEY=not-needed
# Tỉ lệ bộ nhớ GPU vLLM được phép dùng khi scripts/run_all.sh tự khởi động server —
# PHẢI nhỏ hơn tỉ lệ bộ nhớ GPU thực sự còn trống lúc chạy (kiểm tra bằng nvidia-smi/
# free -h trước), nhất là trên máy dùng chung nhiều người. 0.15 là giá trị đã verify
# chạy được cho Qwen3-8B-AWQ trên máy test — chỉnh theo máy bạn.
VLLM_GPU_MEMORY_UTILIZATION=0.15

# TTS: VieNeu-TTS (pnnbao97/VieNeu-TTS, gói pip `vieneu`) qua selfhost/tts_server.py
# (venv riêng .venv-tts) — ĐÃ verify chạy thật cả CPU lẫn GPU (xem selfhost/tts_server.py
# để biết cách cài + benchmark). Model tự tải về ở lần chạy đầu, không cần script tải
# riêng. 14 giọng dựng sẵn, không bắt buộc audio tham chiếu (khác F5-TTS trước đây).
TTS_BACKEND=cloud
VIENEU_SERVER_URL=http://localhost:8100
# true: phát audio ngay từ chunk đầu của infer_stream() (khuyến nghị cho real-time).
# false: đợi tổng hợp xong cả câu rồi nhận một WAV hoàn chỉnh (chỉ để debug/rollback).
VIENEU_STREAMING=true
# Warm-up một câu khi server khởi động để lượt hội thoại đầu không chịu compile/cold-start.
VIENEU_WARMUP=true
# Tên 1 trong 14 giọng dựng sẵn, vd: Trúc Ly, Xuân Vĩnh, Phạm Tuyên, Ngọc Linh, Mai Anh,
# Thái Sơn, Thanh Bình, Đoan Trang, Thục Đoan, Minh Đức, Minh Triết, Thùy Dung, Quang Sơn,
# Ngọc Trân. Bỏ trống dùng giọng mặc định của thư viện (Phạm Tuyên).
VIENEU_VOICE=Trúc Ly
# Chỉ điền nếu muốn voice cloning từ giọng riêng (audio bạn có quyền sử dụng, đã xin
# phép người nói) — ưu tiên hơn VIENEU_VOICE nếu cả hai cùng đặt.
VIENEU_REF_AUDIO=
# auto (mặc định): tự dùng GPU nếu có torch+CUDA trong .venv-tts, không thì CPU (ONNX).
# cpu: ép dùng CPU dù có GPU. BẮT BUỘC đặt "cpu" nếu LLM_BACKEND=local (vLLM) cùng chạy
# trên máy này — đã xảy ra thật: TTS "auto" chọn GPU, vLLM cũng chiếm GPU, TTS crash
# "CUDA error: out of memory" ngay khi có phiên hội thoại thật. CPU là fallback an toàn
# nhưng có thể hụt buffer (lần đo mới p50 RTF ~1.79); nếu máy còn đủ GPU, `cuda` đạt
# p50 first audio 207ms và RTF 0.57 sau warm-up.
VIENEU_DEVICE=cpu
# Cố định repo model để không đổi lặng lẽ nếu bản pip `vieneu` sau này đổi
# default — mặc định đã là bản v3-Turbo (48kHz, nhanh nhất). Đổi nếu muốn thử
# bản khác, vd pnnbao-ump/VieNeu-TTS-v2.
VIENEU_BACKBONE_REPO=pnnbao-ump/VieNeu-TTS-v3-Turbo

# ===== Track B — 7 service phía sau Runtime Scheduler (Vision/Text/Tool/Memory/
# Planning/Reasoning/Generation), tách biệt với LLM_BACKEND của Speech Service ở trên =====
SERVICES_LLM_BACKEND=cloud
SERVICES_VLLM_BASE_URL=http://localhost:8000/v1
SERVICES_VLLM_MODEL=Qwen/Qwen3-8B-AWQ
SERVICES_VLLM_API_KEY=not-needed

# ===== Giai đoạn 2 — Full duplex + cảm xúc (xem duplex/, docs/roadmap.md mục 2) =====
# CHƯA verify bằng hội thoại thật — xem docstring trong duplex/*.py.
# true (mặc định): lọc backchannel tiếng Việt ("dạ"/"vâng"/"ừm") khi bot đang nói, để
# chúng không bị coi là ngắt lời. false: quay lại VAD thuần (ngắt ngay khi có tiếng nói).
DUPLEX_BACKCHANNEL_FILTER=true
# Thời gian cho interim ASR phân biệt "dạ/vâng" trước khi VAD cắt tiếng bot. Nhánh
# Zipformer local không có interim vẫn ngắt sau đúng timeout này thay vì chờ hết câu.
DUPLEX_BARGE_IN_DELAY_MS=200
# none (mặc định): tắt hẳn kênh cảm xúc. heuristic: bật thử đường dây chèn tag cảm xúc
# vào context dựa trên từ khoá trong transcript — KHÔNG phải SER thật trên audio/prosody
# (model thật theo roadmap.md mục 6 là emotion2vec+/SenseVoice, chưa tích hợp).
EMOTION_BACKEND=none

# ===== Dual-path Anchored Speech-to-Speech =====
# off: pipeline ASR-LLM-TTS cũ; shadow: fan-out audio sang backend thử nghiệm nhưng
# không phát output; ack_only: chỉ cho fast path nói câu xác nhận an toàn; speculative:
# cho phép low-risk prefix; primary: ưu tiên S2S nhưng factual/tool vẫn bị hard-gate.
S2S_MODE=shadow
# probe chỉ kiểm tra Audio Hub/latency, KHÔNG phải model. moshi_ws kết nối sidecar
# `python -m moshi.server`; chỉ bật shadow sau khi Mimi codec gate đạt.
S2S_SHADOW_BACKEND=probe
# Ring buffer chỉ nằm trong RAM của Gateway; audio frame không đi qua NATS/Ray.
S2S_AUDIO_RING_MS=30000
# Consumer S2S chậm sẽ drop frame cũ của riêng nó thay vì chặn WebRTC/Anchor ASR.
S2S_SUBSCRIBER_QUEUE_FRAMES=128
# Giao thức chính thức Kyutai: websocket /api/chat, Opus mono 24kHz. Chỉ loopback được
# phép mặc định để tránh vô tình gửi microphone ra máy khác.
MOSHI_URL=ws://127.0.0.1:8998/api/chat
MOSHI_CONNECT_TIMEOUT_S=1.5
# Lần đầu Moshi tải/khởi tạo checkpoint có thể mất nhiều phút.
MOSHI_START_TIMEOUT_S=1800
MOSHI_PROPOSAL_QUEUE_SIZE=8
MOSHI_ALLOW_REMOTE=false
# Dùng bởi `scripts.local_stack start --with-moshi`; checkpoint/cache luôn nằm trong repo.
MOSHI_HF_REPO=kyutai/moshika-pytorch-bf16
MOSHI_DEVICE=cuda
MOSHI_DTYPE=bf16
HF_HOME=.cache/huggingface

# ===== Giai đoạn 3 — datagen/synthetic_dialogue.py (chuẩn bị dữ liệu hội thoại full-
# duplex 2 kênh, docs/roadmap.md mục 8) — không cần GPU, chạy được ngay nếu có đủ key
# ANTHROPIC_API_KEY (ở trên) + ELEVENLABS_API_KEY (ở trên, dùng cho giọng assistant) =====
# ID giọng ElevenLabs riêng cho "user" trong hội thoại giả lập (khác giọng assistant ở
# ELEVENLABS_VOICE_ID phía trên) — lấy tại https://elevenlabs.io/app/voice-library
DATAGEN_USER_VOICE_ID=
# Chỉ cần điền nếu muốn giọng assistant trong dữ liệu sinh ra KHÁC với ELEVENLABS_VOICE_ID
# dùng cho bot thật ở trên.
DATAGEN_ASSISTANT_VOICE_ID=
